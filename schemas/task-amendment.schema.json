  "properties": {"schema_version": {"const": 1}, "amendment_id": {"type": "string", "pattern": "^AMD-[A-Za-z0-9][A-Za-z0-9._-]{1,79}$"}, "task_id": {"type": "string"}, "from_revision": {"type": "integer", "minimum": 1}, "to_revision": {"type": "integer", "minimum": 2}, "amendment_kind": {"enum": ["owner_change", "scope_change", "acceptance_change", "test_change", "review_feedback", "retry", "clarification"]}, "source": {"enum": ["owner", "external_chatgpt", "main", "verifier", "security_reviewer", "critical_reviewer", "system"]}, "changes": {"type": "object", "minProperties": 1, "properties": {"objective": {"type": "string"}, "allowed_paths_add": {"type": "array", "items": {"type": "string"}}, "allowed_paths_remove": {"type": "array", "items": {"type": "string"}}, "forbidden_paths_add": {"type": "array", "items": {"type": "string"}}, "forbidden_paths_remove": {"type": "array", "items": {"type": "string"}}, "acceptance_add": {"type": "array", "items": {"type": "string"}}, "acceptance_remove": {"type": "array", "items": {"type": "string"}}, "targeted_tests_add": {"type": "array", "items": {"type": "string"}}, "targeted_tests_remove": {"type": "array", "items": {"type": "string"}}, "checkpoint_tests_add": {"type": "array", "items": {"type": "string"}}, "checkpoint_tests_remove": {"type": "array", "items": {"type": "string"}}, "manual_verification_add": {"type": "array", "items": {"type": "string"}}, "manual_verification_remove": {"type": "array", "items": {"type": "string"}}, "review_feedback": {"type": "array", "items": {"type": "string"}}, "required_changes": {"type": "array", "items": {"type": "string"}}, "notes": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}, "source_review_role": {"type": "string"}, "source_review_sha256": {"type": "string"}, "previous_contract_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "resulting_contract_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "created_at": {"type": "string", "format": "date-time"}},
  "additionalProperties": false
}
