{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therceman.dev/agent-router/project.schema.json",
  "title": "Agent Router Project",
  "description": "Agent Router project state stored under the user home directory. Work repositories remain zero-footprint.",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "project_id",
    "name",
    "profile",
    "provider",
    "enabled_roles",
    "repository",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "development",
        "secure-development-external-brain",
        "secure-development-local-brain",
        "security-research"
      ]
    },
    "provider": {
      "const": "codex"
    },
    "enabled_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "contains": {
        "const": "main"
      },
      "items": {
        "enum": [
          "main",
          "repo_janitor",
          "scout",
          "implementation_worker",
          "implementation_escalation_worker",
          "verifier",
          "architect",
          "security_reviewer",
          "security_researcher",
          "critical_reviewer"
        ]
      }
    },
    "repository": {
      "type": "object",
      "required": [
        "identity",
        "remote"
      ],
      "properties": {
        "identity": {
          "type": "string",
          "minLength": 1
        },
        "remote": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
