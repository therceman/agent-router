{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therceman.dev/agent-router/machine-bindings.schema.json",
  "title": "Agent Router Machine Bindings",
  "type": "object",
  "required": ["schema_version", "projects"],
  "properties": {
    "schema_version": { "const": 1 },
    "projects": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["repository_path", "updated_at"],
        "properties": {
          "repository_path": { "type": "string", "minLength": 1 },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
