{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therceman.dev/agent-router/phase-route.schema.json",
  "title": "Agent Router Phase Route",
  "type": "object",
  "required": ["schema_version", "task_id", "task_revision", "effective_contract_sha256", "phase", "role", "model_class", "provider_model", "reasoning", "sandbox_mode", "approval_policy", "created_at"],
  "properties": {
    "schema_version": { "const": 1 }, "task_id": { "type": "string" }, "task_revision": { "type": "integer", "minimum": 1 }, "effective_contract_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "phase": { "enum": ["primary", "review"] }, "role": { "type": "string", "not": { "const": "main" } }, "model_class": { "enum": ["cheap", "balanced", "expert"] }, "provider_model": { "type": "string", "minLength": 1 }, "reasoning": { "enum": ["low", "medium", "high", "xhigh"] }, "sandbox_mode": { "enum": ["read-only", "workspace-write"] }, "approval_policy": { "type": "string", "minLength": 1 }, "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
