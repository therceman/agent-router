{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therceman.dev/agent-router/assignment.schema.json",
  "title": "Agent Router Task Assignment",
  "type": "object",
  "required": ["schema_version", "assignment_id", "project_id", "task_id", "task_revision", "session_id", "role", "route_sha256", "context_sha256", "transport_action", "dispatch_command", "dispatch_message", "status", "created_at", "updated_at"],
  "properties": {
    "schema_version": {"const": 1}, "assignment_id": {"type": "string", "pattern": "^ASN-[A-Za-z0-9][A-Za-z0-9._-]{1,79}$"}, "project_id": {"type": "string"}, "task_id": {"type": "string"}, "task_revision": {"type": "integer", "minimum": 1}, "session_id": {"type": "string", "pattern": "^SES-[A-Za-z0-9][A-Za-z0-9._-]{1,79}$"},
    "role": {"type": "string", "not": {"const": "main"}}, "route_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "context_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "transport_action": {"enum": ["spawn", "send_input", "resume"]}, "provider_agent_id": {"type": "string"}, "dispatch_command": {"type": "string", "pattern": "^agent-router work (open|sync|reopen) "}, "dispatch_message": {"type": "string", "pattern": "^Execute:\nagent-router work (open|sync|reopen) "},
    "status": {"enum": ["pending_transport", "transport_confirmed", "acknowledged", "completed", "blocked", "relinquished", "stale", "cancelled"]}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}, "transport_confirmed_at": {"type": "string", "format": "date-time"}, "acknowledged_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": "string", "format": "date-time"}, "failure_code": {"type": "string"}, "failure_detail": {"type": "string"}
  },
  "additionalProperties": false
}
