{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Router Route",
  "type": "object",
  "required": ["schema_version", "task_id", "role", "model_class", "provider_model", "reasoning", "confidence", "hard_rules", "explanation", "scout_required", "review", "budget", "created_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "task_id": { "type": "string" }, "role": { "type": "string" }, "provider_model": { "type": "string", "minLength": 1 },
    "model_class": { "enum": ["cheap", "balanced", "expert"] },
    "reasoning": { "enum": ["low", "medium", "high", "xhigh"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }, "hard_rules": { "type": "array", "items": { "type": "string" } }, "explanation": { "type": "object" }, "scout_required": { "type": "boolean" }, "review": { "type": "object" }, "budget": { "$ref": "task.schema.json#/properties/budgets" }, "created_at": { "type": "string", "format": "date-time" }, "task_revision": { "type": "integer", "minimum": 1 }, "effective_contract_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "phase": { "enum": ["primary", "review"] }, "sandbox_mode": { "enum": ["read-only", "workspace-write"] }, "approval_policy": { "type": "string" }
  },
  "additionalProperties": false
}
