{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therceman.dev/agent-router/session.schema.json",
  "title": "Agent Router Persistent Session",
  "type": "object",
  "required": ["schema_version", "session_id", "project_id", "provider", "role", "model_class", "provider_model", "reasoning", "repository_root", "sandbox_mode", "approval_policy", "status", "compatibility_key", "tasks_completed", "failed_tasks", "rejected_tasks", "created_at", "updated_at", "last_used_at"],
  "properties": {
    "schema_version": {"const": 1},
    "session_id": {"type": "string", "pattern": "^SES-[A-Za-z0-9][A-Za-z0-9._-]{1,79}$"},
    "project_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"},
    "provider": {"const": "codex"},
    "provider_agent_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["repo_janitor", "scout", "implementation_worker", "implementation_escalation_worker", "verifier", "architect", "security_reviewer", "security_researcher", "critical_reviewer"]},
    "model_class": {"enum": ["cheap", "balanced", "expert"]},
    "provider_model": {"type": "string", "minLength": 1},
    "reasoning": {"enum": ["low", "medium", "high", "xhigh"]},
    "repository_root": {"type": "string", "pattern": "^/"},
    "sandbox_mode": {"enum": ["read-only", "workspace-write"]},
    "approval_policy": {"type": "string", "minLength": 1},
    "status": {"enum": ["pending_spawn", "idle", "reserved", "busy", "stale", "retiring", "retired", "failed"]},
    "current_assignment_id": {"type": "string", "pattern": "^ASN-[A-Za-z0-9][A-Za-z0-9._-]{1,79}$"},
    "assigned_task": {"type": "string"}, "assigned_revision": {"type": "integer", "minimum": 1}, "acknowledged_revision": {"type": "integer", "minimum": 1},
    "compatibility_key": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "tasks_completed": {"type": "integer", "minimum": 0}, "failed_tasks": {"type": "integer", "minimum": 0}, "rejected_tasks": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}, "last_used_at": {"type": "string", "format": "date-time"}, "idle_since": {"type": "string", "format": "date-time"}, "lease_expires_at": {"type": "string", "format": "date-time"},
    "retire_reason": {"enum": ["explicit", "task_limit", "failure_limit", "idle_timeout", "implementation_rejected", "scope_violation", "handoff_validation_failed", "model_changed", "reasoning_changed", "role_changed", "repository_changed", "sandbox_changed", "approval_policy_changed", "provider_agent_unavailable", "resume_failed", "session_corrupt", "project_unbound", "project_ejected", "campaign_complete", "critical_freshness_policy"]},
    "retired_at": {"type": "string", "format": "date-time"}, "last_transport_action": {"enum": ["spawn", "send_input", "resume"]}, "last_transport_result": {"enum": ["pending", "succeeded", "failed"]}, "last_transport_error": {"type": "string"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "retired"}}}, "then": {"required": ["retire_reason", "retired_at"]}},
    {"if": {"properties": {"status": {"const": "idle"}}}, "then": {"required": ["provider_agent_id"]}},
    {"if": {"properties": {"status": {"enum": ["reserved", "busy"]}}}, "then": {"required": ["current_assignment_id", "assigned_task", "assigned_revision"]}}
  ],
  "additionalProperties": false
}
