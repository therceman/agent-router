{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therceman.dev/agent-router/state-transaction.schema.json",
  "title": "Agent Router State Transaction",
  "type": "object",
  "required": ["schema_version", "transaction_id", "project_id", "operation", "status", "created_at", "updated_at", "operations"],
  "properties": {
    "schema_version": { "const": 1 },
    "transaction_id": { "type": "string", "pattern": "^TX-[A-Za-z0-9][A-Za-z0-9._-]{1,127}$" },
    "project_id": { "type": "string" },
    "operation": { "type": "string", "minLength": 1 },
    "status": { "enum": ["prepared", "committing", "committed", "rolling_back", "rolled_back", "recovery_required"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "error": { "type": "string" },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "target"],
        "properties": {
          "kind": { "enum": ["write", "move", "remove"] },
          "target": { "type": "string", "minLength": 1 },
          "staged_path": { "type": "string" },
          "backup_path": { "type": "string" },
          "before_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "after_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
